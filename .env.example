# YouTube (optional - falls back to RSS if not set)
# Find your Channel ID: YouTube Studio → Settings → Channel → Advanced settings
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxx
YOUTUBE_API_KEY=your_youtube_data_api_key

# Contact form (add your preferred form provider)
# Options: Formspree, Resend, EmailJS, or Vercel's built-in form handling
CONTACT_FORM_ENDPOINT=https://formspree.io/f/your_form_id
